class ConnectionManager:
    def __init__(self):
        self.office_connections: Dict[int, Set[WebSocket]] = {}
        self.operator_connections: Dict[int, WebSocket] = {}

    async def connect_operator(self, websocket: WebSocket, operator_id: int, office_id: int):
        await websocket.accept()
        self.operator_connections[operator_id] = websocket
        self.office_connections.setdefault(office_id, set()).add(websocket)

    async def broadcast_to_office(self, office_id: int, message: dict):
        for ws in self.office_connections.get(office_id, set()):
            await ws.send_json(message)

    async def notify_operator(self, operator_id: int, message: dict):
        ws = self.operator_connections.get(operator_id)
        if ws:
            await ws.send_json(message)
